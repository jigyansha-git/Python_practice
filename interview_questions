# find the missing number/ missing number = expected sum - actual sum
# here we calculate the sum from 1-6 = n(n+1)/2 = 21
# the actual sum is 17 so 21-17=4
numbers = [1,2,3,5,6]
n = 6
expected_sum = n*(n+1)/2
actual_sum = sum(numbers)
missing_value = expected_sum - actual_sum
print("The missing number is:",missing_value)

    
# find pair with given sum
numbers = [2, 4, 3, 5, 7, 8, 9]
target = 7
for i in range(len(numbers)):
    for j in range(i+1,len(numbers)):
        if numbers[i] + numbers[j] == target:
            print(numbers[i],numbers[j])
  
############# OR ########
numbers = [2,4,3,5,7,8,9]
target = 7
seen = set()
for num in numbers:
    needed = target - num
    if needed in seen:
        print((needed,num))
    seen.add(num)
print(seen)


# Rotate list to the right by k steps
